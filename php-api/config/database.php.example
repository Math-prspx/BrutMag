<?php
// Configuration base de données MySQL
// Copier ce fichier vers database.php et remplir avec vos credentials

class Database {
    private $host = "your_mysql_host.db";        // Ex: mysql5-123.perso ou localhost
    private $db_name = "your_database_name";     // Ex: brutmag_db
    private $username = "your_mysql_username";   // Ex: brutmag_user
    private $password = "your_mysql_password";   // Mot de passe MySQL
    private $conn;

    public function getConnection() {
        $this->conn = null;
        
        try {
            $this->conn = new PDO(
                "mysql:host=" . $this->host . ";dbname=" . $this->db_name . ";charset=utf8mb4",
                $this->username,
                $this->password,
                array(
                    PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
                    PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
                    PDO::ATTR_EMULATE_PREPARES => false
                )
            );
        } catch(PDOException $e) {
            error_log("Connection error: " . $e->getMessage());
            return null;
        }
        
        return $this->conn;
    }
}
